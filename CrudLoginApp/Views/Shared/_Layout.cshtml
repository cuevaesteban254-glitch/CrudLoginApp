<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRUD APP</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #eef2f3, #dfe9f3);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar {
            backdrop-filter: blur(10px);
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.4rem;
            background: linear-gradient(45deg, #4cd137, #00a8ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

            .navbar-brand:hover {
                opacity: 0.8;
            }

        .card {
            border-radius: 18px;
            border: none;
            transition: all 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0px 10px 25px rgba(0,0,0,0.15);
            }

        .btn {
            border-radius: 12px;
            transition: all 0.2s ease-in-out;
        }

            .btn:hover {
                transform: scale(1.05);
            }

        .table {
            border-radius: 12px;
            overflow: hidden;
        }

        .table-hover tbody tr:hover {
            background-color: #f1f2f6;
        }

        h1, h2, h3 {
            font-weight: 700;
            color: #2f3640;
        }

        .fade-in {
            animation: fadeIn 0.8s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

            .form-control:focus {
                border-color: #4cd137;
                box-shadow: 0 0 5px rgba(76, 209, 55, 0.5);
            }

        .btn-success {
            background: linear-gradient(135deg, #4cd137, #44bd32);
            border: none;
        }

        .btn-danger {
            background: linear-gradient(135deg, #e84118, #c23616);
            border: none;
        }

        .btn-info {
            background: linear-gradient(135deg, #00a8ff, #0097e6);
            border: none;
            color: white;
        }

        .btn-warning {
            background: linear-gradient(135deg, #fbc531, #e1b12c);
            border: none;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🚀 CRUD APP
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house"></i> Inicio
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Productos" asp-action="Index">
                            <i class="bi bi-box"></i> Productos
                        </a>
                    </li>
                </ul>

                <partial name="_LoginPartial" />

            </div>
        </div>
    </nav>

    <div class="container mt-4 fade-in">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center mt-5 mb-3 text-muted">
        <small>© 2026 - CRUD APP | Desarrollado en ASP.NET Core</small>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.querySelectorAll(".btn").forEach(btn => {
            btn.addEventListener("click", function () {
                this.style.transform = "scale(0.95)";
                setTimeout(() => {
                    this.style.transform = "scale(1)";
                }, 100);
            });
        });
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>